{
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(npm run *)",
      "Bash(npm test*)",
      "Bash(npx vitest *)",
      "Bash(npx jest *)",
      "Bash(npx tsc *)",
      "Bash(npx eslint *)"
    ],
    "deny": [
      "Bash(git * --no-verify*)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(rm -rf *)"
    ]
  }
}
